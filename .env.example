# OpenRouter — texto/LLM (obrigatório para geração de conteúdo e design)
# Chave: https://openrouter.ai/keys
OPENROUTER_API_KEY=sua-chave-aqui
# Modelo global padrão (fallback, se não usar roteador por tarefa)
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
# Duas etapas (padrão no código se estas linhas forem omitidas):
# 1) Texto/material didático → GPT-4o
OPENROUTER_MODEL_TEXT_MATERIAL=openai/gpt-4o
# 2) Design/layout das páginas → Anthropic Claude Sonnet 4
OPENROUTER_MODEL_DESIGN=anthropic/claude-sonnet-4
# Opcional (recomendado pelo OpenRouter)
# OPENROUTER_HTTP_REFERER=https://seu-dominio.com
# OPENROUTER_X_TITLE=design-beleza

# 3) Imagens nos materiais didáticos (prioridade: OpenRouter; fallback: Gemini direto)
# OpenRouter — mesmo OPENROUTER_API_KEY de cima; modelo de imagem (ex.: google/gemini-2.5-flash-image)
# OPENROUTER_MODEL_IMAGE=google/gemini-2.5-flash-image
# Fallback se não usar OpenRouter para imagens: chave https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Modelo nativo Gemini (só no fallback). Ex.: gemini-2.5-flash-image
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Opcional: imagens na rota /api/generate-material (Hugging Face ou OpenAI)
# HUGGINGFACE_HUB_TOKEN=
# OPENAI_API_KEY=
