# Obtenha em https://console.anthropic.com/ (API Keys)
ANTHROPIC_API_KEY=sua-chave-aqui

# Opcional: para gerar imagens no material. Hugging Face (recomendado, free tier) ou OpenAI.
# HF: https://huggingface.co/settings/tokens (permisso de Inference)
HUGGINGFACE_HUB_TOKEN=
# Ou use HF_TOKEN com o mesmo valor
# OPENAI_API_KEY=  (fallback se HF não estiver configurado)
