# Copie este arquivo para .env.local na raiz do projeto e preencha (não commite segredos).
# Nome do arquivo: exatamente ".env.local" (com a palavra "env"). Não use ".ev.local" nem "env.local".

# --- OpenRouter (obrigatório para geração de texto/design) ---
# https://openrouter.ai/keys
# O app prioriza a chave em .env.local quando ela tem formato válido (evita conflito com variável de sistema antiga).
OPENROUTER_API_KEY=

# Opcional: cabeçalhos enviados à API (alguns ambientes exigem referer/título válidos)
# OPENROUTER_HTTP_REFERER=https://seu-dominio.com
# OPENROUTER_X_TITLE=scribo
# Só para depuração: pula GET /api/v1/key antes da geração (não use em produção)
# OPENROUTER_SKIP_KEY_VERIFY=1

# Modelos por etapa (padrões no código são econômicos: gpt-4o-mini + claude-3.5-haiku).
# Só defina abaixo se quiser modelos premium (mais caros no OpenRouter).
# OPENROUTER_MODEL_TEXT_MATERIAL=openai/gpt-4o-mini
# OPENROUTER_MODEL_DESIGN=anthropic/claude-3.5-haiku
# Geração de imagem via OpenRouter (multimodal). Deixe vazio para não usar esta rota.
OPENROUTER_MODEL_IMAGE=google/gemini-2.5-flash-image

# Opcional: fallback genérico em openRouterChat quando model não é passado
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# --- Google Gemini (opcional: imagens diretas / fallback quando OpenRouter não cobre) ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# --- OpenAI (opcional: DALL-E em fluxos de material; scripts locais) ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Hugging Face (opcional: usado em api/generate-material) ---
# HUGGINGFACE_HUB_TOKEN=
# HF_TOKEN=
